# Airtable — server-side only, never exposed to the client.
# Read/write PAT scoped to the FRAKTUR base only.
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE_WALLETS=Wallets
AIRTABLE_TABLE_FINDINGS=Findings
AIRTABLE_TABLE_DONATIONS=Donations
AIRTABLE_TABLE_SUPPORTERS=Supporters
AIRTABLE_TABLE_SETTINGS=Settings
AIRTABLE_TABLE_FREE_SCAN_APPLICATIONS=FreeScanApplications
AIRTABLE_TABLE_LEADS=Leads

# BTCPay Server — used to create invoices and to verify the webhook signature.
# See README for how to configure the webhook in the BTCPay dashboard.
BTCPAY_URL=https://your-btcpay-instance.example.com
BTCPAY_API_KEY=
BTCPAY_STORE_ID=
BTCPAY_WEBHOOK_SECRET=

# Base URL of this site, used to build the webhook callback / redirect URLs.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Public BTCPay URL, used client-side ONLY to load the embedded checkout
# modal script (btcpay.js). Not secret — do not put the API key here.
NEXT_PUBLIC_BTCPAY_URL=https://your-btcpay-instance.example.com
